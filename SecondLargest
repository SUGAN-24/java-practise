class Solution {

    public int getSecondLargest(int[] arr) {
        int fl = Integer.MIN_VALUE;
        int sl = Integer.MIN_VALUE;

        for (int i : arr) {
            if (i > fl) {
                sl = fl;
                fl = i;
            } 
            else if (i != fl && i > sl) {
                sl = i;
            }
        }

        if (sl == Integer.MIN_VALUE) {
            return -1;
        }

        return sl;
    }

}